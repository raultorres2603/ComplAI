{
  "cityId": "elprat",
  "cityName": "El Prat de Llobregat",
  "officialSources": [
    "https://www.elprat.cat/",
    "https://www.pratespais.com/",
    "https://tramits.pratespais.com/Ciutadania/"
  ],
  "newsSources": [
    "https://www.instagram.com/elprataldia/"
  ],
  "baseUrl": "https://tramits.pratespais.com/Ciutadania/TramitsTemes.aspx",
  "s3Region": "eu-west-1",
  "crawl": {
    "categoryLinkSelector": "div.LlistaTemes.LlistatMenu ul.llistat a[href]",
    "detailLinkSelector": "a[href*='DetallTramit.aspx']",
    "detailLinkExcludePattern": "Tramitar=True"
  },
  "fields": {
    "title": {
      "selector": "span.iconesTramit, span.titolTramit",
      "multiple": false
    },
    "description": {
      "selector": ".introduccio",
      "multiple": false
    },
    "requirements": {
      "selector": ".introduccio ul",
      "multiple": true
    },
    "steps": {
      "selector": ".block, .blockFirst",
      "multiple": false
    }
  },
  "skip": {
    "whenTitleEmptyOrEquals": [
      "Portal de Tràmits"
    ]
  },
  "events": {
    "baseUrl": "https://www.elprat.cat/la-ciutat/guia-agenda",
    "crawl": {
      "eventLinkSelector": "a[href^='/la-ciutat/guia-agenda/']",
      "eventDetailExcludePattern": ""
    },
    "fields": {
      "title": {
        "selector": "h1.page-header, h1.titol, h2.event-title, .node-title",
        "multiple": false
      },
      "description": {
        "selector": ".field-name-body, .event-description, .field--name-body, .field--type-text-with-summary",
        "multiple": false
      },
      "eventType": {
        "selector": ".field-name-field-tipus-acte, .event-type, .field--name-field-tipus-acte",
        "multiple": false
      },
      "targetAudience": {
        "selector": ".field-name-field-per-a-qui, .event-audience, .field--name-field-per-a-qui",
        "multiple": true
      },
      "date": {
        "selector": ".field-name-field-data, .event-date, .field--name-field-data",
        "multiple": false
      },
      "time": {
        "selector": ".field-name-field-hora, .event-time, .field--name-field-hora",
        "multiple": false
      },
      "location": {
        "selector": ".field-name-field-lloc, .event-location, .field--name-field-lloc",
        "multiple": false
      },
      "theme": {
        "selector": ".field-name-field-tema, .event-theme, .field--name-field-tema",
        "multiple": false
      }
    }
  }
}