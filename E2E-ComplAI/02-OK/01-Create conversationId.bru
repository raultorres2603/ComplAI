meta {
  name: Create conversationId
  type: http
  seq: 1
}

get {
  url: https://echo.usebruno.com
  body: none
  auth: none
}

script:post-response {
  function uuidv4() {
    // https://stackoverflow.com/a/2117523/2715716
    return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {
      var r = Math.random() * 16 | 0, v = c === 'x' ? r : (r & 0x3 | 0x8);
      return v.toString(16);
    });
  }

  let conversationId = uuidv4();
  console.log("Created conversationId: " + conversationId);
  bru.setEnvVar("conversationId", conversationId);

  // Parse SSE stream into a structured object for downstream tests
  const rawBody = typeof res.body === 'string' ? res.body : JSON.stringify(res.body);
  const parsed = parseSse(rawBody);
  bru.setVar("parsedResponse", parsed);
  console.log("Parsed SSE response:", JSON.stringify(parsed));
}

/**
 * Parse SSE stream lines (e.g. "data: {...}\n") into a structured object.
 * Extracts all chunk contents into message, collects type events, etc.
 */
function parseSse(sse) {
  const lines = sse.split('\n');
  const eventTypes = {};
  let message = '';
  let fullResponse = '';
  let sources = [];
  let done = false;

  for (const line of lines) {
    const trimmed = line.trim();
    if (!trimmed || !trimmed.startsWith('data: ')) continue;

    let dataStr = trimmed.substring('data: '.length);

    // SSE format may have trailing newline after the JSON object
    if (dataStr.endsWith('\n')) dataStr = dataStr.slice(0, -1);
    if (dataStr.endsWith('\r')) dataStr = dataStr.slice(0, -1);

    let data;
    try {
      data = JSON.parse(dataStr);
    } catch (e) {
      console.warn('Failed to parse SSE data line:', dataStr);
      continue;
    }

    const type = data.type || '';
    const content = data.content || '';

    fullResponse += content;

    if (type === 'chunk') {
      message += content;
    } else if (type === 'sources') {
      sources = data.sources || [];
    } else if (type === 'done') {
      done = true;
    }

    // Store named event data (e.g., { type: 'error', code: 0 })
    if (type) {
      eventTypes[type] = data;
    }
  }

  return {
    fullResponse,
    message,
    sources,
    done,
    errorCode: (eventTypes.error && eventTypes.error.code !== undefined) ? eventTypes.error.code : 0,
    success: (eventTypes.done && !eventTypes.error) || (!eventTypes.error && message.length > 0),
  };
}

settings {
  encodeUrl: true
  timeout: 0
}